import ecdsa

# Замените на путь к вашему приватному ключу или используйте публичный
with open("private_key.pem", "rb") as f:
    sk = ecdsa.SigningKey.from_pem(f.read())
    vk = sk.verifying_key

# Экспорт в сырые байты (64 байта)
raw_key = vk.to_string() 
print("Copy this to your g_public_key in C:")
print(", ".join([f"0x{b:02X}" for b in raw_key]))
